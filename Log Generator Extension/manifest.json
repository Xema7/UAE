{
  "manifest_version": 3,
  "name": "User Action Logger",
  "version": "1.0",
  "description": "Local-only user behavior logging (JSONL)",
  "permissions": ["tabs", "storage", "webNavigation", "downloads"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
